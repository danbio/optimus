# Copiar para .env e preencher os valores
# Gerar SECRET_KEY com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=substitua-por-chave-gerada-acima
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Produção PostgreSQL (deixar comentado em dev — usa SQLite)
